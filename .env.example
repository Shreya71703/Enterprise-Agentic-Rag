# =============================================================================
# Enterprise RAG System — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# Google Gemini API Key (required for embeddings & LLM)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# --- Optional: Groq (Alternative LLM) ---------------------------------------
# GROQ_API_KEY=your-groq-api-key-here

# --- Optional: Unstructured.io Hosted API ------------------------------------
# Only needed if using hosted mode instead of local parsing.
# Get yours at: https://unstructured.io/api-key-hosted
# UNSTRUCTURED_API_KEY=your-unstructured-api-key-here
# UNSTRUCTURED_API_URL=https://api.unstructuredapp.io/general/v0/general

# --- Optional: Cohere Re-ranker (Step 3) ------------------------------------
# COHERE_API_KEY=your-cohere-api-key-here

# --- Optional: Tavily Web Search (Step 4) -----------------------------------
# TAVILY_API_KEY=your-tavily-api-key-here
